# ─── Migdal 365 · הגדרות סביבה ──────────────────────────────────────────────
# העתיקו קובץ זה ל-.env ומלאו ערכים. קבצי .env לא עולים ל-Git (ראו .gitignore).

# מצב עבודה: mock (פיתוח, ללא Microsoft 365) | msal (ייצור, SSO מלא)
VITE_AUTH_MODE=mock

# ─── Microsoft Entra ID (Enterprise Application) ───
VITE_TENANT_ID=
VITE_CLIENT_ID=
VITE_REDIRECT_URI=http://localhost:5173

# ─── Microsoft Graph ───
VITE_GRAPH_ENDPOINT=https://graph.microsoft.com/v1.0

# ─── SharePoint Online (דרך Graph) — פורמט: host:/sites/name ───
VITE_SHAREPOINT_SITE=

# UPN-ים שיקבלו הרשאת מנהל מערכת (מופרדים בפסיק)
VITE_ADMIN_UPNS=eran@migdal-haemeq.muni.il

# ⚠️ אבטחה: אפליקציית SPA משתמשת ב-OAuth 2.0 + PKCE ואינה זקוקה ל-Client Secret.
# לעולם אין לשים Client Secret בקוד צד-לקוח — הוא נחשף לכל משתמש.
# אם יידרש Secret (לרכיב שרת עתידי) — הוא יישמר בשרת בלבד, לא בקובץ זה.
